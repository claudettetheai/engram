# ============================================
# Engram — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Only DATABASE_URL is required. Everything else has sensible defaults.

# ---- REQUIRED ----

# PostgreSQL connection string (must have pgvector + pg_trgm extensions)
DATABASE_URL="postgresql://user:password@localhost:5432/your_database"

# ---- OPTIONAL ----

# Anthropic API key (for artifact extraction + consolidation)
# If not set, falls back to local LLM extraction via Ollama/MLX
ANTHROPIC_API_KEY=

# Anthropic model for artifact extraction (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=

# Embedding model (default: Xenova/bge-base-en-v1.5, runs locally)
# No API key needed — embeddings run on your machine
EMBEDDING_MODEL=

# Schema name in PostgreSQL (default: claude_memory)
MEMORY_SCHEMA=claude_memory

# Maximum database pool connections (default: 3)
DB_POOL_MAX=3

# Database connection timeout in ms (default: 5000)
DB_CONNECT_TIMEOUT=5000

# Database idle timeout in ms (default: 10000)
DB_IDLE_TIMEOUT=10000
